# Copy this file to .env and fill in your provider's details.
# The backend speaks the OpenAI-compatible chat completions format,
# so any of the providers below (or others like it) work without code changes.

# Port the Express backend listens on
PORT=3001

# --- Pick ONE provider and uncomment its two lines below ---

# Groq (free tier, fast) — https://console.groq.com/keys
AI_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.1-8b-instant

# OpenRouter (free-tier models available) — https://openrouter.ai/keys
# AI_BASE_URL=https://openrouter.ai/api/v1
# AI_MODEL=meta-llama/llama-3.1-8b-instruct:free

# OpenAI
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini

# Ollama, running locally — no key needed, just leave AI_API_KEY as any string
# AI_BASE_URL=http://localhost:11434/v1
# AI_MODEL=llama3.1

AI_API_KEY=your-api-key-here
